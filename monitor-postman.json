{
  "info": {
    "name": "Monitor de Indicadores API",
    "description": "Collection simples para testar a API NestJS da atividade.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "auditorToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "municipioId",
      "value": "1"
    },
    {
      "key": "relatorioId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "01 - Help público",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/help",
          "host": ["{{baseUrl}}"],
          "path": ["help"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Login Master",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"master@sistema.com\",\n  \"senha\": \"master123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login realizado', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "const json = pm.response.json();",
              "if (json.accessToken) {",
              "  pm.collectionVariables.set('token', json.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Listar municípios",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/municipios",
          "host": ["{{baseUrl}}"],
          "path": ["municipios"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Criar usuário Admin Público",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Administrador Público de Natal\",\n  \"email\": \"admin.natal@sistema.com\",\n  \"senha\": \"admin123\",\n  \"role\": \"ROLE_ADMIN_PUBLICO\",\n  \"municipioId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": ["{{baseUrl}}"],
          "path": ["usuarios"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Usuário criado ou já existente', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Criar usuário Auditor",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Auditor do Sistema\",\n  \"email\": \"auditor@sistema.com\",\n  \"senha\": \"auditor123\",\n  \"role\": \"ROLE_AUDITOR\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": ["{{baseUrl}}"],
          "path": ["usuarios"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Usuário criado ou já existente', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06 - Criar relatório",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Relatório de Mortalidade Infantil\",\n  \"descricao\": \"Indicador municipal de mortalidade infantil para acompanhamento anual.\",\n  \"ano\": 2024,\n  \"nomeIndicador\": \"Taxa de mortalidade infantil\",\n  \"valorIndicador\": 12.5,\n  \"municipioId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/relatorios",
          "host": ["{{baseUrl}}"],
          "path": ["relatorios"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Relatório criado', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "if (json.id) {",
              "  pm.collectionVariables.set('relatorioId', json.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 - Consultar relatórios do município",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/relatorios/municipio/{{municipioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["relatorios", "municipio", "{{municipioId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "08 - Atualizar relatório",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Relatório atualizado de Mortalidade Infantil\",\n  \"valorIndicador\": 10.8\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/relatorios/{{relatorioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["relatorios", "{{relatorioId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "09 - Login Auditor",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"auditor@sistema.com\",\n  \"senha\": \"auditor123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login do auditor realizado', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "const json = pm.response.json();",
              "if (json.accessToken) {",
              "  pm.collectionVariables.set('auditorToken', json.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "10 - Municípios como Auditor",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{auditorToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/municipios",
          "host": ["{{baseUrl}}"],
          "path": ["municipios"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Auditor acessa municípios', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "11 - Auditor sem permissão em relatórios",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{auditorToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/relatorios/municipio/{{municipioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["relatorios", "municipio", "{{municipioId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 403', function () {",
              "  pm.response.to.have.status(403);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "12 - Município inexistente",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/relatorios/municipio/999",
          "host": ["{{baseUrl}}"],
          "path": ["relatorios", "municipio", "999"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', function () {",
              "  pm.response.to.have.status(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "13 - Excluir relatório",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/relatorios/{{relatorioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["relatorios", "{{relatorioId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', function () {",
              "  pm.response.to.have.status(204);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "14 - Excluir usuário inexistente",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
